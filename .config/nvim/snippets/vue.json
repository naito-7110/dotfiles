{
  "SFC script setup": {
    "prefix": "vbase",
    "body": [
      "<script setup lang=\"ts\">",
      "$1",
      "</script>",
      "",
      "<template>",
      "\t<div :class=\"$style.${2:root}\">$0</div>",
      "</template>",
      "",
      "<style module>",
      ".${2:root} {",
      "}",
      "</style>"
    ],
    "description": "Vue SFC (<script setup lang=ts>, CSS Modules)"
  },
  "ref": {
    "prefix": "ref",
    "body": ["const ${1:name} = ref(${2:value});"],
    "description": "ref()"
  },
  "computed": {
    "prefix": "cmpt",
    "body": ["const ${1:name} = computed(() => $0);"],
    "description": "computed()"
  },
  "onMounted": {
    "prefix": "onmounted",
    "body": ["onMounted(() => {", "\t$0", "});"],
    "description": "onMounted()"
  }
}
