{
  "fenced code block": {
    "prefix": "code",
    "body": ["```${1:lang}", "$0", "```"],
    "description": "fenced code block"
  },
  "link": {
    "prefix": "link",
    "body": ["[${1:text}](${2:url})"],
    "description": "link"
  },
  "table": {
    "prefix": "table",
    "body": ["| ${1:col1} | ${2:col2} |", "| --- | --- |", "| $3 | $4 |"],
    "description": "2-column table"
  },
  "details": {
    "prefix": "details",
    "body": ["<details>", "<summary>${1:summary}</summary>", "", "$0", "", "</details>"],
    "description": "collapsible details"
  },
  "bold": {
    "prefix": "bold",
    "body": ["**${1:text}**"],
    "description": "bold"
  },
  "italic": {
    "prefix": "italic",
    "body": ["*${1:text}*"],
    "description": "italic"
  },
  "task list item": {
    "prefix": "task",
    "body": ["- [ ] $0"],
    "description": "task checkbox"
  },
  "blockquote": {
    "prefix": "quote",
    "body": ["> $0"],
    "description": "blockquote"
  },
  "image": {
    "prefix": "img",
    "body": ["![${1:alt}](${2:url})"],
    "description": "image"
  }
}
